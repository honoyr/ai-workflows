{
  "permissions": {
    "allow": [
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "mcp__pal__listmodels",
      "mcp__pal__chat",
      "Bash(git add:*)"
    ],
    "deny": [
      "Bash(curl *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(rm*)"
    ]
  },
  "defaultMode": "bypassPermissions"
}
